      "Bash(git -C * add *)",
      "Bash(git -C * check-ignore *)",
      "Bash(git -C * commit *)",
      "Bash(git -C * diff *)",
      "Bash(git -C * log *)",
      "Bash(git -C * show *)",
      "Bash(git -C * status *)",
      "Bash(git add *)",
      "Bash(git check-ignore *)",
      "Bash(git commit *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git status *)",
      "Bash(grep *)",
      "Bash(jq *)",
      "Bash(kubectl -n * auth can-i *)",
      "Bash(kubectl -n * describe *)",
      "Bash(kubectl -n * diff *)",
      "Bash(kubectl -n * events *)",
      "Bash(kubectl -n * events)",
      "Bash(kubectl -n * get *)",
      "Bash(kubectl -n * logs *)",
      "Bash(kubectl -n * top *)",
      "Bash(kubectl -n * wait *)",
      "Bash(kubectl api-resources *)",
      "Bash(kubectl api-resources)",
      "Bash(kubectl api-versions *)",
      "Bash(kubectl api-versions)",
      "Bash(kubectl auth can-i *)",
      "Bash(kubectl auth whoami *)",
      "Bash(kubectl auth whoami)",
      "Bash(kubectl cluster-info *)",
      "Bash(kubectl cluster-info)",
      "Bash(kubectl config current-context)",
      "Bash(kubectl config get-contexts *)",
      "Bash(kubectl config get-contexts)",
      "Bash(kubectl config view *)",
      "Bash(kubectl config view)",
      "Bash(kubectl describe *)",
      "Bash(kubectl diff *)",
      "Bash(kubectl events *)",
      "Bash(kubectl events)",
      "Bash(kubectl explain *)",
      "Bash(kubectl get *)",
      "Bash(kubectl logs *)",
      "Bash(kubectl top *)",
      "Bash(kubectl version *)",
      "Bash(kubectl version)",
      "Bash(kubectl wait *)",
      "Bash(ls *)",
      "Bash(npm run build*)",
      "Bash(npm run format:fix*)",
      "Bash(npm run lint*)",
      "Bash(npm run lint:fix*)",
      "Bash(npm run type-check*)",
      "Bash(npx eslint *)",
      "Bash(npx markdownlint-cli2 *)",
      "Bash(npx tsc *)",
      "Bash(sort *)",
      "Bash(tail *)",
      "Bash(uv run pyright*)",
      "Bash(uv run pytest*)",
      "Bash(uv run ruff*)",
      "Bash(wc)",
      "Bash(xargs *)",
      "WebSearch"
    ],
    "deny": [
      "Bash(git commit*)"
    ],
    "ask": [
      "Bash(curl*)",
      "Bash(gh pr create*)",
      "Bash(rm *)",
      "Read(*.env)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/bin/notify.sh 'Claude Code' 'Waiting for your input'"
          }
        ]
      },
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/bin/notify.sh 'Claude Code' 'Permission required'"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "model": "sonnet"
}
