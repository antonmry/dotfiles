prefix_rule(pattern=["curl"], decision="prompt")
prefix_rule(pattern=["dig"], decision="allow")
prefix_rule(pattern=["find"], decision="allow")
prefix_rule(pattern=["grep"], decision="allow")
prefix_rule(pattern=["jq"], decision="allow")
prefix_rule(pattern=["ls"], decision="allow")
prefix_rule(pattern=["make", "validate"], decision="allow")
prefix_rule(pattern=["npm", "run", ["build","format:fix","lint","lint:fix","type-check",]], decision="allow")
prefix_rule(pattern=["npx", ["eslint","markdownlint-cli2","tsc"]], decision="allow")
prefix_rule(pattern=["rg"], decision="allow")
prefix_rule(pattern=["rm"], decision="forbidden")
prefix_rule(pattern=["sort"], decision="allow")
prefix_rule(pattern=["tail"], decision="allow")
prefix_rule(pattern=["uv", "run", ["pyright","pytest","ruff"]], decision="allow")
prefix_rule(pattern=["wc"], decision="allow")
prefix_rule(pattern=["xargs"], decision="allow")
